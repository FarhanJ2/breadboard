---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import ScribbleBackground from "../components/ScribbleBackground.astro";

interface Props {
  title: string;
  description?: string;
  scribbles?: boolean;
}
const {
  title,
  description = "Farhan Jamil — a journal of engineering, robotics & lived experiments.",
  scribbles = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=Caveat:wght@500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
    <ClientRouter />
  </head>
  <body>
    {scribbles && <ScribbleBackground />}
    <slot />
  </body>
</html>
