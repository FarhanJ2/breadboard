---
/**
 * Embeds an external site in a framed iframe on desktop. On small screens an
 * iframe is cramped and janky, so below the breakpoint we DON'T render the frame
 * at all — we show a tap-to-open link instead. Both point at the same URL.
 *
 * The target must be iframe-embeddable (no X-Frame-Options / restrictive CSP).
 */
interface Props {
  /** external URL to embed */
  src: string;
  /** label shown in the toolbar and on the mobile button */
  title?: string;
  /** frame height on desktop, in px */
  height?: number;
}
const { src, title = "Embedded tool", height = 640 } = Astro.props;
// what to show in the toolbar / button: the host + path, no scheme
const pretty = src.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<figure class="embed">
  <div class="embed__bar mono" aria-hidden="true">
    <span class="embed__dots"><i></i><i></i><i></i></span>
    <span class="embed__url">{pretty}</span>
    <a href={src} target="_blank" rel="noopener" class="embed__open">open ↗</a>
  </div>

  <div class="embed__frame" style={`--h:${height}px`}>
    <iframe
      src={src}
      title={title}
      loading="lazy"
      referrerpolicy="no-referrer"
      sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
    ></iframe>
  </div>

  <a href={src} target="_blank" rel="noopener" class="embed__mobile mono">
    <span>open {title} ↗</span>
    <small>opens in a new tab — best on a larger screen</small>
  </a>
</figure>

<style>
  .embed {
    margin: 26px 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-inset);
  }

  /* Break out of the narrow (~760px) writeup column on desktop so embedded
     tools get real room — centered on the viewport, capped so it never
     overflows. margin-left aligns the embed's centre with the column's. */
  @media (min-width: 721px) {
    .embed {
      width: min(94vw, 1180px);
      margin-left: calc(50% - min(94vw, 1180px) / 2);
    }
  }

  /* fake browser chrome */
  .embed__bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    font-size: 12px;
    color: var(--ink-faint);
    background: var(--bg-raise);
    border-bottom: 1px solid var(--line);
  }
  .embed__dots { display: inline-flex; gap: 5px; flex: none; }
  .embed__dots i {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--line);
  }
  .embed__url {
    flex: 1; min-width: 0;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    letter-spacing: -0.01em;
  }
  .embed__open { flex: none; color: var(--ink-soft); }
  .embed__open:hover { color: var(--amber); text-decoration: none; }

  .embed__frame { position: relative; height: var(--h); }
  .embed__frame iframe {
    width: 100%; height: 100%;
    border: 0; display: block;
    background: #0b0d12;
  }

  /* mobile fallback link — hidden on desktop */
  .embed__mobile { display: none; }

  @media (max-width: 720px) {
    /* an iframe is too cramped to be useful here — swap it for a link */
    .embed__bar, .embed__frame { display: none; }
    .embed__mobile {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 18px 16px;
      color: var(--amber);
      font-size: 0.95rem;
    }
    .embed__mobile:hover { text-decoration: none; }
    .embed__mobile small {
      color: var(--ink-faint);
      font-size: 0.78rem;
      letter-spacing: 0.02em;
    }
  }
</style>
