---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/url";

interface Props {
  project: CollectionEntry<"projects">;
  variant?: "grid" | "mini";
}
const { project, variant = "grid" } = Astro.props;
const { title, codename, blurb, year, status, tech, stat, links, cover, coverAlt } = project.data;
const href = withBase(`/projects/${project.id}`);

const statusLabel: Record<string, string> = {
  shipped: "SHIPPED",
  active: "ACTIVE",
  research: "RESEARCH",
  archived: "ARCHIVED",
};

// external links only — the project's own writeup is the card itself (/projects/<slug>)
const linkList: { label: string; href: string }[] = [
  links.github && { label: "code", href: links.github },
  links.docs && { label: "docs", href: links.docs },
  links.demo && { label: "demo", href: links.demo },
  ...links.more,
].filter(Boolean) as { label: string; href: string }[];
---

<article class={`pcard pcard--${variant} ${cover || variant === "mini" ? "pcard--cover" : ""}`} data-status={status}>
  {/* grid cards aren't wrapped in a link, so the thumb is one; mini cards sit
     inside an outer <a>, so their thumb must be a plain element (no nesting).
     mini cards always get a thumb — a blueprint "screen" when there's no photo,
     so a row of them reads as one consistent set. */}
  {cover && variant === "grid" && (
    <a href={href} class="pcard__thumb" tabindex="-1" aria-hidden="true">
      <img src={withBase(cover)} alt={coverAlt || title} loading="lazy" decoding="async" />
    </a>
  )}
  {variant === "mini" && (
    <span class="pcard__thumb" aria-hidden="true">
      {cover
        ? <img src={withBase(cover)} alt={coverAlt || title} loading="lazy" decoding="async" />
        : <span class="pcard__grid"></span>}
    </span>
  )}
  <div class="pcard__head">
    <span class="led" aria-hidden="true"></span>
    <span class="status mono">{statusLabel[status]}</span>
    <span class="codename mono">{codename}</span>
    <span class="year mono">{year}</span>
  </div>

  <h3 class="pcard__title">
    {variant === "grid" ? <a href={href}>{title}</a> : title}
  </h3>
  <p class="pcard__blurb">{blurb}</p>

  {variant === "grid" && (
    <>
      {stat && (
        <p class="pcard__stat mono">{stat.label} <b>{stat.value}</b></p>
      )}
      {tech.length > 0 && (
        <ul class="tech" aria-label="built with">
          {tech.map((t) => <li class="mono">{t}</li>)}
        </ul>
      )}
      <div class="pcard__links">
        <a href={href} class="mono open">open the writeup <span aria-hidden="true">→</span></a>
        {linkList.map((l) => (
          <a href={l.href} class="mono" target="_blank" rel="noopener">
            {l.label} <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </>
  )}

  {variant === "mini" && stat && (
    <p class="pcard__stat mono">{stat.label} <b>{stat.value}</b></p>
  )}
</article>

<style>
  .pcard {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-raise);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px 18px 16px;
  }

  /* cover thumbnail bleeds to the card edges above the header */
  .pcard--cover { padding-top: 0; overflow: hidden; }
  .pcard__thumb {
    display: block;
    margin: 0 -18px 14px;
    aspect-ratio: 16 / 9;
    background: var(--bg-inset);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }
  .pcard__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .pcard--cover:hover .pcard__thumb img { transform: scale(1.03); }
  /* mini cards use 16px padding, so the bleed margin matches */
  .pcard--mini.pcard--cover { padding-top: 0; }
  .pcard--mini .pcard__thumb { margin: 0 -16px 12px; }
  /* blueprint "screen" fallback when a mini card has no cover photo */
  .pcard__grid {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--bg-inset);
    background-image:
      linear-gradient(rgba(120, 150, 230, 0.09) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120, 150, 230, 0.09) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(120% 100% at 32% 40%, #000 42%, transparent 92%);
  }

  .pcard__head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    color: var(--ink-faint);
    font-size: 11px;
    letter-spacing: 0.12em;
  }
  .led {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex: none;
    background: var(--st);
    box-shadow: 0 0 8px 0 var(--st);
  }
  .status { color: var(--st); }
  .codename { color: var(--ink-soft); }
  .year { margin-left: auto; opacity: 0.8; }

  /* status → color */
  .pcard[data-status="shipped"] { --st: var(--phosphor); }
  .pcard[data-status="active"] { --st: var(--amber); }
  .pcard[data-status="research"] { --st: var(--blueprint); }
  .pcard[data-status="archived"] { --st: var(--ink-faint); }

  .pcard__title {
    margin: 0 0 6px;
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .pcard__title a { color: inherit; }
  .pcard__title a:hover { color: var(--amber); text-decoration: none; }
  .pcard__blurb {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .pcard__stat {
    margin: 14px 0 0;
    color: var(--ink-faint);
  }
  .pcard__stat b { color: var(--phosphor); font-weight: 600; }

  .tech {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 14px 0 0;
    padding: 0;
  }
  .tech li {
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 3px 7px 2px;
  }

  .pcard__links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 16px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px dashed var(--line);
  }
  .pcard__links a {
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: var(--ink-soft);
  }
  .pcard__links a:hover { color: var(--amber); text-decoration: none; }
  .pcard__links a.open { color: var(--amber); margin-right: auto; }

  /* mini (landing strip) is tighter */
  .pcard--mini { padding: 16px; }
  .pcard--mini .pcard__title { font-size: 1.15rem; }
  .pcard--mini .pcard__blurb {
    font-size: 0.92rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
