---
/**
 * DriverStationExplorer
 * ---------------------
 * Part data for the driver station; all behaviour lives in PartExplorer.
 * Renders in /public/projects/driver-station/.
 */
import PartExplorer from "./PartExplorer.astro";
import type { Part } from "./partExplorer";

const parts: Part[] = [
  {
    key: "backplate", side: "left", kicker: "Back plate", hx: 41, hy: 70,
    desc: "Spray painted aluminum plate. The structural support for the driver station and a decorative piece.",
  },
  {
    key: "leds", side: "left", kicker: "LED status bar", hx: 53, hy: 57,
    desc: "The HawkLights bar. A 3D printed diffuser with W2812B LEDs inside controlled via a Raspberry Pi Pico.",
  },
  {
    key: "display", side: "right", kicker: "Display mount", hx: 74, hy: 20,
    desc: "PLA 3d printed mount to hold a 7 inch touch screen for the driver to view at for information for as an operator console. ",
  },
  {
    key: "ethernet", side: "right", kicker: "Ethernet pass-through", hx: 78, hy: 60,
    desc: "An ethernet port for connecting to the FMS or into the robot.",
  },
];
---

<PartExplorer
  base="/projects/driver-station"
  full="full.png"
  label="Driver Station"
  parts={parts}
/>
