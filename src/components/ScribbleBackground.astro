---
/**
 * ScribbleBackground
 * -------------------
 * Full-page ambient line art that randomly circulates between themed GROUPS:
 *   1. abstract  — orbits, waveforms, spirals, constellations, bursts, loops
 *   2. math      — plots, a unit circle, Newton's method, a rotation matrix, integrals
 *   3. physics   — a shoot-on-the-move projectile diagram + the real launch equations
 *   4. code      — excerpts of Farhan's actual SOTM turret solver
 *
 * One group is on screen at a time: it draws itself in (paths via stroke-dashoffset,
 * text via a left→right "writing" wipe), holds, erases, then a different random group
 * takes over. Fixed behind content, aria-hidden, faint. Respects reduced motion.
 */

const C = {
  amber: "#ffb454",
  blue: "hsl(222 80% 72%)",
  green: "#7ee0a8",
  purple: "hsl(276 74% 78%)",
  coral: "#f0906a",
  cyan: "#63d3e6",
  pink: "#ff92b6",
};

function mulberry32(seed: number) {
  return () => {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const f = (n: number) => Math.round(n * 10) / 10;
const rot2 = (x: number, y: number, a: number): [number, number] => [
  x * Math.cos(a) - y * Math.sin(a), x * Math.sin(a) + y * Math.cos(a),
];
function shuffle<T>(arr: T[], r: () => number) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(r() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; }
  return a;
}
const pick = <T,>(arr: T[], r: () => number) => arr[Math.floor(r() * arr.length)];
const TAU = Math.PI * 2;

type Prim =
  | { t: "p"; d: string; c: string; faint?: boolean }
  | { t: "c"; cx: number; cy: number; r: number; c: string; faint?: boolean }
  | { t: "l"; x1: number; y1: number; x2: number; y2: number; c: string; faint?: boolean }
  | { t: "t"; x: number; y: number; s: string; size: number; font: "mono" | "math" | "hand"; c: string; faint?: boolean };
type Cluster = { transform: string; prims: Prim[] };
type Group = { name: string; clusters: Cluster[] };

// ---------- shared drawing helpers (absolute viewBox coords) ----------
function arrow(x1: number, y1: number, x2: number, y2: number, c: string): Prim[] {
  const a = Math.atan2(y2 - y1, x2 - x1), h = 10;
  return [
    { t: "l", x1, y1, x2, y2, c },
    { t: "l", x1: x2, y1: y2, x2: x2 - h * Math.cos(a - 0.4), y2: y2 - h * Math.sin(a - 0.4), c },
    { t: "l", x1: x2, y1: y2, x2: x2 - h * Math.cos(a + 0.4), y2: y2 - h * Math.sin(a + 0.4), c },
  ];
}
function codeBlock(x: number, y: number, lines: [string, string][], size = 12): Prim[] {
  return lines.map((ln, i) => ({
    t: "t", x, y: y + i * (size * 1.5), s: ln[0], size, font: "mono", c: ln[1], faint: ln[1] === C.green ? false : true,
  }));
}

// ================= GROUP 1 — ABSTRACT =================
function gWaves(seed: number): Prim[] {
  const r = mulberry32(seed), cols = shuffle([C.green, C.blue, C.coral, C.amber, C.cyan], r), out: Prim[] = [];
  for (let k = 0; k < 4; k++) {
    const y0 = -48 + k * 30, amp = 9 + r() * 15, cyc = 2 + Math.floor(r() * 3), ph = r() * TAU;
    let d = "";
    for (let x = -175; x <= 175; x += 7) d += (x === -175 ? "M" : "L") + f(x) + " " + f(y0 + amp * Math.sin(((x + 175) / 350) * cyc * TAU + ph)) + " ";
    out.push({ t: "p", d, c: cols[k % cols.length] });
  }
  return out;
}
function gSpiral(seed: number): Prim[] {
  const r = mulberry32(seed), cols = shuffle([C.amber, C.purple, C.cyan, C.pink], r), out: Prim[] = [];
  const turns = 3 + r() * 1.6, dir = r() < 0.5 ? 1 : -1, b = 150 / (turns * TAU), steps = Math.floor(turns * 44);
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const th = (i / steps) * turns * TAU, rad = b * th, x = Math.cos(th * dir) * rad, y = Math.sin(th * dir) * rad;
    d += (i === 0 ? "M" : "L") + f(x) + " " + f(y) + " ";
    if (i % 40 === 0 && i > 0) out.push({ t: "c", cx: x, cy: y, r: 3.5, c: pick(cols, r) });
  }
  out.unshift({ t: "p", d, c: cols[0] });
  return out;
}
function gOrbits(seed: number): Prim[] {
  const r = mulberry32(seed), cols = shuffle([C.blue, C.amber, C.pink, C.cyan, C.green], r), out: Prim[] = [];
  for (let k = 0; k < 3; k++) {
    const rx = 58 + k * 30, ry = 26 + k * 12, rot = r() * Math.PI;
    let d = ""; const s = 44;
    for (let i = 0; i <= s; i++) { const th = (i / s) * TAU; const [x, y] = rot2(Math.cos(th) * rx, Math.sin(th) * ry, rot); d += (i === 0 ? "M" : "L") + f(x) + " " + f(y) + " "; }
    out.push({ t: "p", d: d + "Z", c: cols[k % cols.length] });
    const th = r() * TAU; const [nx, ny] = rot2(Math.cos(th) * rx, Math.sin(th) * ry, rot);
    out.push({ t: "c", cx: nx, cy: ny, r: 4.5, c: cols[(k + 2) % cols.length] });
  }
  out.push({ t: "c", cx: 0, cy: 0, r: 3, c: C.amber });
  return out;
}
function gConstellation(seed: number): Prim[] {
  const r = mulberry32(seed), cols = [C.cyan, C.amber, C.green, C.pink, C.purple, C.blue];
  const pts = Array.from({ length: 8 }, () => ({ x: (r() * 2 - 1) * 140, y: (r() * 2 - 1) * 120, c: pick(cols, r) }));
  const out: Prim[] = [];
  pts.forEach((p, i) => {
    const near = pts.map((q, j) => ({ j, d: (q.x - p.x) ** 2 + (q.y - p.y) ** 2 })).filter((o) => o.j !== i).sort((a, b) => a.d - b.d);
    for (let m = 0; m < (r() < 0.5 ? 1 : 2); m++) { const j = near[m].j; if (i < j) out.push({ t: "l", x1: p.x, y1: p.y, x2: pts[j].x, y2: pts[j].y, c: C.blue, faint: true }); }
  });
  pts.forEach((p) => out.push({ t: "c", cx: p.x, cy: p.y, r: 3 + r() * 3, c: p.c }));
  return out;
}
function gBurst(seed: number): Prim[] {
  const r = mulberry32(seed), cols = [C.amber, C.coral, C.green, C.cyan, C.purple, C.pink, C.blue], out: Prim[] = [];
  for (let i = 0; i < 13; i++) {
    const a = (i / 13) * TAU + r() * 0.12, len = 46 + r() * 82, c = cols[i % cols.length];
    out.push({ t: "l", x1: Math.cos(a) * 14, y1: Math.sin(a) * 14, x2: Math.cos(a) * len, y2: Math.sin(a) * len, c });
    out.push({ t: "c", cx: Math.cos(a) * len, cy: Math.sin(a) * len, r: 3, c });
  }
  out.push({ t: "c", cx: 0, cy: 0, r: 11, c: C.amber });
  return out;
}
function closedSmooth(p: [number, number][]) {
  const n = p.length;
  let d = `M${f(p[0][0])} ${f(p[0][1])} `;
  for (let i = 0; i < n; i++) {
    const p0 = p[(i - 1 + n) % n], p1 = p[i], p2 = p[(i + 1) % n], p3 = p[(i + 2) % n];
    const c1x = p1[0] + (p2[0] - p0[0]) / 6, c1y = p1[1] + (p2[1] - p0[1]) / 6;
    const c2x = p2[0] - (p3[0] - p1[0]) / 6, c2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += `C${f(c1x)} ${f(c1y)}, ${f(c2x)} ${f(c2y)}, ${f(p2[0])} ${f(p2[1])} `;
  }
  return d + "Z";
}
function gLoop(seed: number): Prim[] {
  const r = mulberry32(seed), cols = shuffle([C.purple, C.coral, C.green, C.blue, C.pink], r), out: Prim[] = [];
  for (let s = 0; s < 2; s++) {
    const nn = 6 + Math.floor(r() * 2), rad = 78 - s * 30;
    const pts: [number, number][] = Array.from({ length: nn }, (_, i) => {
      const a = (i / nn) * TAU, rr = rad * (0.55 + r() * 0.75);
      return [Math.cos(a) * rr, Math.sin(a) * rr];
    });
    out.push({ t: "p", d: closedSmooth(pts), c: cols[s % cols.length] });
  }
  return out;
}
const abstractGroup: Group = {
  name: "abstract",
  clusters: [
    { transform: "translate(1230 170) scale(0.9)", prims: gOrbits(11) },
    { transform: "translate(1285 500) scale(0.85)", prims: gWaves(22) },
    { transform: "translate(1150 760) scale(0.9)", prims: gSpiral(33) },
    { transform: "translate(200 720) scale(0.9)", prims: gConstellation(44) },
    { transform: "translate(130 430) scale(0.82)", prims: gBurst(55) },
    { transform: "translate(560 620) scale(0.8)", prims: gWaves(66) },
    { transform: "translate(430 170) scale(0.8)", prims: gConstellation(77) },
    { transform: "translate(880 260) scale(0.85)", prims: gSpiral(88) },
    { transform: "translate(720 440) scale(0.72)", prims: gOrbits(99) },
    { transform: "translate(1030 700) scale(0.8)", prims: gBurst(111) },
    { transform: "translate(360 480) scale(0.7)", prims: gLoop(122) },
    { transform: "translate(1080 380) scale(0.68)", prims: gConstellation(133) },
    { transform: "translate(680 800) scale(0.72)", prims: gLoop(144) },
  ],
};

// ================= GROUP 2 — MATH (graph-forward) =================
function coordPlot(ox: number, oy: number, W: number): Prim[] {
  const out: Prim[] = [];
  const faint = (p: Prim): Prim => ({ ...p, faint: true });
  arrow(ox - 26, oy, ox + W + 22, oy, C.blue).forEach((p) => out.push(faint(p)));
  arrow(ox, oy + 118, ox, oy - 178, C.blue).forEach((p) => out.push(faint(p)));
  for (let x = ox + 52; x < ox + W; x += 56) out.push({ t: "l", x1: x, y1: oy - 5, x2: x, y2: oy + 5, c: C.blue, faint: true });
  for (let y = oy - 34; y > oy - 168; y -= 34) out.push({ t: "l", x1: ox - 5, y1: y, x2: ox + 5, y2: y, c: C.blue, faint: true });
  for (let y = oy + 34; y < oy + 108; y += 34) out.push({ t: "l", x1: ox - 5, y1: y, x2: ox + 5, y2: y, c: C.blue, faint: true });
  const curve = (fn: (t: number) => number, c: string) => {
    let d = "";
    for (let i = 0; i <= 64; i++) { const t = i / 64; d += (i === 0 ? "M" : "L") + f(ox + t * W) + " " + f(fn(t)) + " "; }
    out.push({ t: "p", d, c });
  };
  const sine = (t: number) => oy - 60 * Math.sin(t * 3 * TAU);
  const decay = (t: number) => oy - 122 * Math.exp(-2.6 * t);
  const para = (t: number) => oy - 155 * t * t;
  curve(sine, C.blue);
  curve(decay, C.cyan);
  curve(para, C.green);
  // tangent on the parabola — a little derivative viz
  const t0 = 0.72, x0 = ox + t0 * W, y0 = para(t0), slope = (-310 * t0) / W;
  out.push({ t: "l", x1: x0 - 74, y1: y0 - slope * 74, x2: x0 + 74, y2: y0 + slope * 74, c: C.amber });
  out.push({ t: "c", cx: x0, cy: y0, r: 4, c: C.amber });
  // small captions on the curves themselves (not floating equations)
  out.push({ t: "t", x: ox + 0.1 * W, y: sine(0.083) - 10, s: "sin x", size: 14, font: "math", c: C.blue, faint: true });
  out.push({ t: "t", x: ox + 12, y: decay(0) - 8, s: "e^(−ct)", size: 14, font: "math", c: C.cyan, faint: true });
  out.push({ t: "t", x: ox + W + 8, y: para(1) + 4, s: "x²", size: 15, font: "math", c: C.green, faint: true });
  out.push({ t: "t", x: x0 + 10, y: y0 - 12, s: "dy/dx", size: 12, font: "math", c: C.amber, faint: true });
  return out;
}
function unitCircleGraph(ox: number, oy: number, rr: number): Prim[] {
  const out: Prim[] = [];
  let cd = ""; const s = 48;
  for (let i = 0; i <= s; i++) { const th = (i / s) * TAU; cd += (i === 0 ? "M" : "L") + f(ox + Math.cos(th) * rr) + " " + f(oy + Math.sin(th) * rr) + " "; }
  out.push({ t: "p", d: cd + "Z", c: C.amber });
  out.push({ t: "l", x1: ox - rr - 10, y1: oy, x2: ox + rr + 10, y2: oy, c: C.amber, faint: true });
  out.push({ t: "l", x1: ox, y1: oy + rr + 10, x2: ox, y2: oy - rr - 10, c: C.amber, faint: true });
  const a = -0.95, tx = ox + Math.cos(a) * rr, ty = oy + Math.sin(a) * rr;
  arrow(ox, oy, tx, ty, C.pink).forEach((p) => out.push(p));
  out.push({ t: "l", x1: tx, y1: ty, x2: tx, y2: oy, c: C.green, faint: true }); // sin
  out.push({ t: "l", x1: tx, y1: ty, x2: ox, y2: ty, c: C.blue, faint: true });  // cos
  out.push({ t: "c", cx: tx, cy: ty, r: 4, c: C.pink });
  out.push({ t: "t", x: ox + 12, y: oy - 8, s: "θ", size: 16, font: "math", c: C.pink });
  out.push({ t: "t", x: tx + 6, y: (oy + ty) / 2, s: "sin", size: 12, font: "math", c: C.green, faint: true });
  out.push({ t: "t", x: (ox + tx) / 2 - 12, y: oy + 16, s: "cos", size: 12, font: "math", c: C.blue, faint: true });
  return out;
}
function parametric(cx: number, cy: number, fn: (t: number) => [number, number], c: string, closed = true): Prim {
  let d = ""; const N = 96;
  for (let i = 0; i <= N; i++) { const [x, y] = fn(i / N); d += (i === 0 ? "M" : "L") + f(cx + x) + " " + f(cy + y) + " "; }
  return { t: "p", d: d + (closed ? "Z" : ""), c };
}
function lissajous(cx: number, cy: number, R: number, c: string): Prim[] {
  return [
    parametric(cx, cy, (t) => { const T = t * TAU; return [R * Math.sin(3 * T + Math.PI / 2), R * 0.82 * Math.sin(2 * T)]; }, c),
    { t: "t", x: cx - 18, y: cy + R + 20, s: "Lissajous", size: 12, font: "math", c, faint: true },
  ];
}
function rose(cx: number, cy: number, R: number, k: number, c: string): Prim[] {
  return [
    parametric(cx, cy, (t) => { const T = t * TAU; const r = R * Math.cos(k * T); return [r * Math.cos(T), r * Math.sin(T)]; }, c),
    { t: "t", x: cx - 26, y: cy + R + 20, s: "r = cos kθ", size: 12, font: "math", c, faint: true },
  ];
}
function dampedWave(ox: number, oy: number, W: number, c: string): Prim[] {
  const out: Prim[] = [];
  out.push({ t: "l", x1: ox - 10, y1: oy, x2: ox + W + 10, y2: oy, c: C.blue, faint: true });
  let d = "", e = "";
  for (let i = 0; i <= 90; i++) { const t = i / 90; d += (i === 0 ? "M" : "L") + f(ox + t * W) + " " + f(oy - 78 * Math.exp(-2.4 * t) * Math.cos(t * 5 * TAU)) + " "; }
  for (let i = 0; i <= 45; i++) { const t = i / 45; e += (i === 0 ? "M" : "L") + f(ox + t * W) + " " + f(oy - 78 * Math.exp(-2.4 * t)) + " "; }
  out.push({ t: "p", d, c });
  out.push({ t: "p", d: e, c: C.amber, faint: true });
  out.push({ t: "t", x: ox + W - 96, y: oy - 60, s: "e^(−ct) cos ωt", size: 12, font: "math", c, faint: true });
  return out;
}
function scatterPlot(ox: number, oy: number, W: number, H: number, seed: number): Prim[] {
  const r = mulberry32(seed), out: Prim[] = [];
  out.push({ t: "l", x1: ox - 8, y1: oy, x2: ox + W + 8, y2: oy, c: C.green, faint: true });
  out.push({ t: "l", x1: ox, y1: oy + 8, x2: ox, y2: oy - H - 8, c: C.green, faint: true });
  const pts: [number, number][] = [];
  for (let i = 0; i < 11; i++) { const x = (i / 10) * W, y = (0.12 + 0.72 * (i / 10)) * H + (r() * 2 - 1) * 17; pts.push([x, y]); out.push({ t: "c", cx: ox + x, cy: oy - y, r: 3, c: C.green }); }
  const n = pts.length; let sx = 0, sy = 0, sxy = 0, sxx = 0;
  pts.forEach(([x, y]) => { sx += x; sy += y; sxy += x * y; sxx += x * x; });
  const m = (n * sxy - sx * sy) / (n * sxx - sx * sx), b = (sy - m * sx) / n;
  out.push({ t: "l", x1: ox, y1: oy - b, x2: ox + W, y2: oy - (m * W + b), c: C.amber });
  out.push({ t: "t", x: ox + 6, y: oy - H - 6, s: "ŷ = mx + b", size: 12, font: "math", c: C.amber, faint: true });
  return out;
}
function rightTriangle(cx: number, cy: number): Prim[] {
  const A: [number, number] = [cx - 72, cy + 44], B: [number, number] = [cx + 72, cy + 44], V: [number, number] = [cx - 72, cy - 58];
  return [
    { t: "l", x1: A[0], y1: A[1], x2: B[0], y2: B[1], c: C.blue },
    { t: "l", x1: B[0], y1: B[1], x2: V[0], y2: V[1], c: C.blue },
    { t: "l", x1: V[0], y1: V[1], x2: A[0], y2: A[1], c: C.blue },
    { t: "l", x1: A[0], y1: A[1] - 15, x2: A[0] + 15, y2: A[1] - 15, c: C.blue, faint: true },
    { t: "l", x1: A[0] + 15, y1: A[1] - 15, x2: A[0] + 15, y2: A[1], c: C.blue, faint: true },
    { t: "t", x: cx - 6, y: cy + 60, s: "a", size: 12, font: "math", c: C.blue, faint: true },
    { t: "t", x: cx + 4, y: cy - 4, s: "c", size: 12, font: "math", c: C.blue, faint: true },
    { t: "t", x: cx - 90, y: cy - 4, s: "b", size: 12, font: "math", c: C.blue, faint: true },
    { t: "t", x: B[0] - 30, y: B[1] - 8, s: "θ", size: 13, font: "math", c: C.pink },
    { t: "t", x: cx - 96, y: cy - 74, s: "a² + b² = c²", size: 13, font: "math", c: C.blue, faint: true },
  ];
}
function eqns(x: number, y: number, items: [string, string, number][]): Prim[] {
  return items.map((it, i) => ({ t: "t", x, y: y + i * (it[2] * 1.7), s: it[0], size: it[2], font: "math" as const, c: it[1], faint: false }));
}
