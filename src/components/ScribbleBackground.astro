const groups: Group[] = [abstractGroup, mathGroup, codeGroup];

// ================= GROUP 4 — MARKER (fat white strokes) =================
// each stroke is a tapered ribbon (thick at the tip, thinning toward the tail)
// revealed by a masked stroke that sweeps along the centerline like a real marker.
function sampleCurve(ctrl: [number, number][], per = 16): [number, number][] {
  const n = ctrl.length;
  const at = (i: number) => ctrl[Math.max(0, Math.min(n - 1, i))];
  const P: [number, number][] = [];
  for (let i = 0; i < n - 1; i++) {
    const p0 = at(i - 1), p1 = at(i), p2 = at(i + 1), p3 = at(i + 2);
    for (let j = 0; j < per; j++) {
      const t = j / per, t2 = t * t, t3 = t2 * t;
      P.push([
        0.5 * (2 * p1[0] + (-p0[0] + p2[0]) * t + (2 * p0[0] - 5 * p1[0] + 4 * p2[0] - p3[0]) * t2 + (-p0[0] + 3 * p1[0] - 3 * p2[0] + p3[0]) * t3),
        0.5 * (2 * p1[1] + (-p0[1] + p2[1]) * t + (2 * p0[1] - 5 * p1[1] + 4 * p2[1] - p3[1]) * t2 + (-p0[1] + 3 * p1[1] - 3 * p2[1] + p3[1]) * t3),
      ]);
    }
  }
  P.push(ctrl[n - 1]);
  return P;
}
type Marker = { ribbon: string; center: string; tip: [number, number]; tail: [number, number]; w: number };
/**
 * Chisel-nib ribbon. A real marker's width isn't a function of distance along
 * the stroke — it's the projection of a fixed-angle nib onto the direction of
 * travel. Offsetting the centerline by a CONSTANT vector along the nib axis
 * reproduces that exactly: sweeping across the nib gives a fat stroke, sweeping
 * along it gives a hairline, and the ends come out as flat angled chisel cuts.
 * `minHalf` is the nib's narrow edge, so a parallel sweep thins out instead of
 * collapsing to nothing.
 */
function chiselRibbon(
  P: [number, number][], nibHalf: number, nibAngle: number, minHalf: number,
  jitter = 0, rng: () => number = Math.random
): Marker {
  const ux = Math.cos(nibAngle), uy = Math.sin(nibAngle);
  const left: string[] = [], right: string[] = [];
  for (let j = 0; j < P.length; j++) {
    const t = j / (P.length - 1);
    const a = P[Math.max(0, j - 1)], b = P[Math.min(P.length - 1, j + 1)];
    let nx = -(b[1] - a[1]), ny = b[0] - a[0];
    const len = Math.hypot(nx, ny) || 1; nx /= len; ny /= len;
    // hand lifting off at the end of the swipe
    const lift = t > 0.88 ? Math.max(0.32, 1 - ((t - 0.88) / 0.12) * 0.68) : 1;
    const h = nibHalf * lift, m = minHalf * lift;
    // Ragged ink edge, baked into the geometry instead of a live SVG filter
    // (filters over full-screen strokes re-run every frame → ~7fps). Jitter the
    // two sides INDEPENDENTLY along the travel normal so the band reads chalky,
    // not just wavy — moving both edges together keeps it a hard-edged slab.
    const jl = jitter ? (rng() * 2 - 1) * jitter : 0;
    const jr = jitter ? (rng() * 2 - 1) * jitter : 0;
    left.push(`${f(P[j][0] + ux * h + nx * (m + jl))} ${f(P[j][1] + uy * h + ny * (m + jl))}`);
    right.push(`${f(P[j][0] - ux * h - nx * (m + jr))} ${f(P[j][1] - uy * h - ny * (m + jr))}`);
  }
  return {
    ribbon: "M" + left.join(" L") + " L" + right.reverse().join(" L") + " Z",
    center: "M" + P.map((p) => `${f(p[0])} ${f(p[1])}`).join(" L"),
    tip: P[0], tail: P[P.length - 1], w: (nibHalf + minHalf) * 2,
  };
}
function markerStroke(seed: number): Marker {
  const r = mulberry32(seed);
  const ctrl: [number, number][] = [];
  let x = 120 + r() * 1180, y = 120 + r() * 640, ang = r() * TAU;
  for (let k = 0; k < 3; k++) {
    ctrl.push([x, y]);
    const step = 340 + r() * 320;
    // gentle drift only — a swipe is a confident sweep, not a squiggle
    ang += (r() * 2 - 1) * 0.5;
    x = Math.max(50, Math.min(1390, x + Math.cos(ang) * step));
    y = Math.max(50, Math.min(850, y + Math.sin(ang) * step));
  }
  // one hand holds the marker at a near-constant angle across every stroke
  const nibAngle = -0.62 + (r() * 2 - 1) * 0.22;
  // more samples = finer ragged edge; jitter reproduces the old dry-marker filter
  return chiselRibbon(sampleCurve(ctrl, 40), 13 + r() * 8, nibAngle, 1.7 + r() * 1.3, 1.3, r);
}
const markerData: Marker[] = Array.from({ length: 12 }, (_, i) => markerStroke(700 + i * 53));


// a casually-pinned tilt per cluster so nothing sits perfectly flat
const tiltAngles = [-8, 6, -4, 9, -6, 3, -9, 7, -3, 5, -7, 4, -5, 8, -2];
const tiltOf = (gi: number, ci: number) => tiltAngles[(gi * 7 + ci * 5) % tiltAngles.length];
