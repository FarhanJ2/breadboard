---
/**
 * ScribbleBackground
 * -------------------
 * Ambient, abstract, multi-colored line art scattered in the page margins. Each motif
 * (orbits, waveforms, spirals, constellations, bursts, flowing loops) is generated
 * procedurally and draws itself in via stroke-dashoffset. Every slot cycles between a
 * couple of variants on its own phase, so the background is always quietly changing.
 *
 * Fixed behind content, aria-hidden, pointer-events:none. Respects reduced motion.
 */

// ---- palette (each motif mixes a few of these) ---------------------------
const C = {
  amber: "#ffb454",
  blue: "hsl(222 80% 71%)",
  green: "#7ee0a8",
  purple: "hsl(276 74% 77%)",
  coral: "#f0906a",
  cyan: "#63d3e6",
  pink: "#ff92b6",
};

// ---- tiny deterministic RNG so SSR output is stable ----------------------
function mulberry32(seed: number) {
  return () => {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const f = (n: number) => Math.round(n * 10) / 10;
const rot2 = (x: number, y: number, a: number): [number, number] => [
  x * Math.cos(a) - y * Math.sin(a),
  x * Math.sin(a) + y * Math.cos(a),
];
function shuffle<T>(arr: T[], r: () => number) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(r() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
const pick = <T,>(arr: T[], r: () => number) => arr[Math.floor(r() * arr.length)];

// ---- prim types ----------------------------------------------------------
type Prim =
  | { t: "p"; d: string; c: string; faint?: boolean }
  | { t: "c"; cx: number; cy: number; r: number; c: string; faint?: boolean }
  | { t: "l"; x1: number; y1: number; x2: number; y2: number; c: string; faint?: boolean };

const TAU = Math.PI * 2;

function ellipsePath(rx: number, ry: number, rot: number) {
  let d = "";
  const s = 44;
  for (let i = 0; i <= s; i++) {
    const th = (i / s) * TAU;
    const [x, y] = rot2(Math.cos(th) * rx, Math.sin(th) * ry, rot);
    d += (i === 0 ? "M" : "L") + f(x) + " " + f(y) + " ";
  }
  return d + "Z";
}
function closedSmooth(p: [number, number][]) {
  const n = p.length;
  let d = `M${f(p[0][0])} ${f(p[0][1])} `;
  for (let i = 0; i < n; i++) {
    const p0 = p[(i - 1 + n) % n], p1 = p[i], p2 = p[(i + 1) % n], p3 = p[(i + 2) % n];
    const c1x = p1[0] + (p2[0] - p0[0]) / 6, c1y = p1[1] + (p2[1] - p0[1]) / 6;
    const c2x = p2[0] - (p3[0] - p1[0]) / 6, c2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += `C${f(c1x)} ${f(c1y)}, ${f(c2x)} ${f(c2y)}, ${f(p2[0])} ${f(p2[1])} `;
  }
  return d + "Z";
}

// ---- motif generators (local coords, centered on 0,0) --------------------
function gWaves(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = shuffle([C.green, C.blue, C.coral, C.amber, C.cyan], r);
  const out: Prim[] = [];
  for (let k = 0; k < 4; k++) {
    const y0 = -48 + k * 30, amp = 9 + r() * 15, cyc = 2 + Math.floor(r() * 3), ph = r() * TAU;
    let d = "";
    for (let x = -175; x <= 175; x += 7) {
      const y = y0 + amp * Math.sin(((x + 175) / 350) * cyc * TAU + ph);
      d += (x === -175 ? "M" : "L") + f(x) + " " + f(y) + " ";
    }
    out.push({ t: "p", d, c: cols[k % cols.length] });
  }
  return out;
}
function gSpiral(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = shuffle([C.amber, C.purple, C.cyan, C.pink], r);
  const out: Prim[] = [];
  const turns = 3 + r() * 1.6, dir = r() < 0.5 ? 1 : -1, maxR = 150, b = maxR / (turns * TAU);
  const steps = Math.floor(turns * 44);
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const th = (i / steps) * turns * TAU, rad = b * th;
    const x = Math.cos(th * dir) * rad, y = Math.sin(th * dir) * rad;
    d += (i === 0 ? "M" : "L") + f(x) + " " + f(y) + " ";
    if (i % 40 === 0 && i > 0) out.push({ t: "c", cx: x, cy: y, r: 3.5, c: pick(cols, r) });
  }
  out.unshift({ t: "p", d, c: cols[0] });
  out.push({ t: "c", cx: 0, cy: 0, r: 4, c: cols[1] });
  return out;
}
function gOrbits(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = shuffle([C.blue, C.amber, C.pink, C.cyan, C.green], r);
  const out: Prim[] = [];
  for (let k = 0; k < 3; k++) {
    const rx = 58 + k * 30, ry = 26 + k * 12, rot = r() * Math.PI;
    out.push({ t: "p", d: ellipsePath(rx, ry, rot), c: cols[k % cols.length] });
    const th = r() * TAU;
    const [nx, ny] = rot2(Math.cos(th) * rx, Math.sin(th) * ry, rot);
    out.push({ t: "c", cx: nx, cy: ny, r: 4.5, c: cols[(k + 2) % cols.length] });
  }
  out.push({ t: "c", cx: 0, cy: 0, r: 3, c: C.amber });
  return out;
}
function gConstellation(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = [C.cyan, C.amber, C.green, C.pink, C.purple, C.blue];
  const pts = Array.from({ length: 9 }, () => ({
    x: (r() * 2 - 1) * 150, y: (r() * 2 - 1) * 130, c: pick(cols, r),
  }));
  const out: Prim[] = [];
  pts.forEach((p, i) => {
    const near = pts
      .map((q, j) => ({ j, d: (q.x - p.x) ** 2 + (q.y - p.y) ** 2 }))
      .filter((o) => o.j !== i)
      .sort((a, b) => a.d - b.d);
    const k = r() < 0.5 ? 1 : 2;
    for (let m = 0; m < k; m++) {
      const j = near[m].j;
      if (i < j) out.push({ t: "l", x1: p.x, y1: p.y, x2: pts[j].x, y2: pts[j].y, c: C.blue, faint: true });
    }
  });
  pts.forEach((p) => out.push({ t: "c", cx: p.x, cy: p.y, r: 3 + r() * 3, c: p.c }));
  return out;
}
function gBurst(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = [C.amber, C.coral, C.green, C.cyan, C.purple, C.pink, C.blue];
  const out: Prim[] = [];
  const n = 13;
  for (let i = 0; i < n; i++) {
    const a = (i / n) * TAU + r() * 0.12, len = 46 + r() * 82, c = cols[i % cols.length];
    out.push({ t: "l", x1: Math.cos(a) * 14, y1: Math.sin(a) * 14, x2: Math.cos(a) * len, y2: Math.sin(a) * len, c });
    out.push({ t: "c", cx: Math.cos(a) * len, cy: Math.sin(a) * len, r: 3, c });
  }
  out.push({ t: "c", cx: 0, cy: 0, r: 11, c: C.amber });
  return out;
}
function gLoop(seed: number): Prim[] {
  const r = mulberry32(seed);
  const cols = shuffle([C.purple, C.coral, C.green, C.blue, C.pink], r);
  const out: Prim[] = [];
  for (let s = 0; s < 2; s++) {
    const nn = 6 + Math.floor(r() * 2), rad = 78 - s * 30;
    const pts: [number, number][] = Array.from({ length: nn }, (_, i) => {
      const a = (i / nn) * TAU, rr = rad * (0.55 + r() * 0.75);
      return [Math.cos(a) * rr, Math.sin(a) * rr];
    });
    out.push({ t: "p", d: closedSmooth(pts), c: cols[s % cols.length] });
  }
  return out;
}

// ---- slots: position + two motif variants each ---------------------------
type Gen = (seed: number) => Prim[];
const slotDefs: { x: number; y: number; s: number; gens: [Gen, Gen] }[] = [
  { x: 1225, y: 185, s: 0.9, gens: [gOrbits, gConstellation] },   // top-right
  { x: 1290, y: 480, s: 0.85, gens: [gWaves, gSpiral] },          // right-mid
  { x: 1175, y: 720, s: 0.9, gens: [gLoop, gBurst] },             // bottom-right
  { x: 190, y: 715, s: 0.9, gens: [gSpiral, gConstellation] },    // bottom-left
  { x: 120, y: 455, s: 0.82, gens: [gBurst, gWaves] },            // left-mid
  { x: 930, y: 235, s: 0.85, gens: [gConstellation, gLoop] },     // upper-center-right
];
const slots = slotDefs.map((sd, i) => ({
  transform: `translate(${sd.x} ${sd.y}) scale(${sd.s})`,
  variants: [sd.gens[0](1000 + i * 97), sd.gens[1](5000 + i * 131)] as Prim[][],
}));
---

<div class="scribble-bg" aria-hidden="true">
  <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" fill="none">
    {slots.map((slot, si) => (
      <g class="scribble-slot" data-slot={si} transform={slot.transform}>
        {slot.variants.map((prims, vi) => (
          <g class="variant" data-variant={vi} hidden={vi !== 0}>
            {prims.map((p) =>
              p.t === "p" ? (
                <path class:list={["ink", p.faint && "faint"]} pathLength="1" d={p.d} style={`--c:${p.c}`} />
              ) : p.t === "c" ? (
                <circle class:list={["ink", p.faint && "faint"]} pathLength="1" cx={p.cx} cy={p.cy} r={p.r} style={`--c:${p.c}`} />
              ) : (
                <line class:list={["ink", p.faint && "faint"]} pathLength="1" x1={p.x1} y1={p.y1} x2={p.x2} y2={p.y2} style={`--c:${p.c}`} />
              )
            )}
          </g>
        ))}
      </g>
    ))}
  </svg>
</div>

<style>
  .scribble-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }
  .scribble-bg svg { width: 100%; height: 100%; }

  .ink {
    fill: none;
    stroke: var(--c, #ffb454);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-opacity: 0.5;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
  .ink.faint { stroke-opacity: 0.22; }

  .variant.drawn .ink { stroke-dashoffset: 0; }
  .variant.drawing .ink {
    animation: sb-draw 1.5s ease forwards;
    animation-delay: calc(var(--i, 0) * 45ms);
  }
  .variant.erasing .ink {
    animation: sb-erase 0.85s ease forwards;
    animation-delay: calc(var(--i, 0) * 18ms);
  }
  @keyframes sb-draw { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }
  @keyframes sb-erase { from { stroke-dashoffset: 0; } to { stroke-dashoffset: 1; } }

  /* margins collapse on small screens — hide the art there */
  @media (max-width: 820px) {
    .scribble-bg { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ink { stroke-dashoffset: 0 !important; animation: none !important; }
    .variant[hidden] { display: none; }
  }
</style>

<script>
  function initScribbles(root: ParentNode) {
    const svg = root.querySelector(".scribble-bg svg");
    if (!svg) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const slots = Array.from(svg.querySelectorAll<SVGGElement>(".scribble-slot"));

    for (const slot of slots) {
      const variants = Array.from(slot.querySelectorAll<SVGGElement>(":scope > .variant"));
      for (const v of variants) {
        Array.from(v.querySelectorAll<SVGElement>(".ink")).forEach((el, i) =>
          el.style.setProperty("--i", String(i)),
        );
      }
      if (reduce) {
        variants.forEach((v, i) => {
          v.hidden = i !== 0;
          if (i === 0) v.classList.add("drawn");
        });
      }
    }
    if (reduce) return;

    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));
    let running = true;

    slots.forEach((slot, si) => {
      const variants = Array.from(slot.querySelectorAll<SVGGElement>(":scope > .variant"));
      const drawMs = (v: Element) => v.querySelectorAll(".ink").length * 45 + 1500;
      const eraseMs = (v: Element) => v.querySelectorAll(".ink").length * 18 + 850;
      let k = 0;
      let looping = false;

      async function loop() {
        if (looping) return;
        looping = true;
        while (running) {
          const v = variants[k % variants.length];
          v.hidden = false;
          v.classList.remove("erasing");
          v.classList.add("drawing");
          await wait(drawMs(v) + 3600 + Math.random() * 2600); // hold, desynced per slot
          if (!running) break;
          v.classList.remove("drawing");
          v.classList.add("erasing");
          await wait(eraseMs(v));
          v.classList.remove("erasing");
          v.hidden = true;
          k++;
          await wait(300);
        }
        looping = false;
      }
      // stagger each slot's first draw so they don't all appear at once
      setTimeout(loop, si * 650 + Math.random() * 500);

      slot.dataset.loop = "1";
      (slot as any).__loop = loop;
    });

    document.addEventListener("visibilitychange", () => {
      running = document.visibilityState === "visible";
      if (running) slots.forEach((s) => (s as any).__loop?.());
    });
  }

  initScribbles(document);
</script>
