<div class="scribble-bg" aria-hidden="true">
  <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" fill="none">
    {groups.map((group, gi) => (
      <g class="scribble-group is-hidden" data-group={group.name}>
        {group.clusters.map((cl, ci) => (
          <g transform={cl.transform}>
            <g class="tilt" style={`--tilt:${tiltOf(gi, ci)}deg`}>
              <g class="drift" style={`--phase:${ci}`}>
              {cl.prims.map((p) =>
                p.t === "p" ? (
                  <path class:list={["ink", p.faint && "faint"]} pathLength="1" d={p.d} style={`--c:${p.c}`} />
                ) : p.t === "c" ? (
                  <circle class:list={["ink", p.faint && "faint"]} pathLength="1" cx={p.cx} cy={p.cy} r={p.r} style={`--c:${p.c}`} />
                ) : p.t === "l" ? (
                  <line class:list={["ink", p.faint && "faint"]} pathLength="1" x1={p.x1} y1={p.y1} x2={p.x2} y2={p.y2} style={`--c:${p.c}`} />
                ) : (
                  <text class:list={["ink-text", `f-${p.font}`, p.faint && "faint"]} x={p.x} y={p.y} font-size={p.size} style={`--c:${p.c}`}>{p.s}</text>
                )
              )}
              </g>
            </g>
          </g>
        ))}
      </g>
    ))}

    <g class="scribble-group is-hidden" data-group="marker">
      <defs>
        {markerData.map((m, i) => (
          <linearGradient id={`mkg-${i}`} gradientUnits="userSpaceOnUse" x1={m.tip[0]} y1={m.tip[1]} x2={m.tail[0]} y2={m.tail[1]}>
            {/* ink pools where the nib lands, stays fairly even through the
                swipe, then runs out as the hand lifts */}
            <stop offset="0" stop-color="#fdfdfb" stop-opacity="0.60" />
            <stop offset="0.12" stop-color="#fdfdfb" stop-opacity="0.52" />
            <stop offset="0.72" stop-color="#fdfdfb" stop-opacity="0.42" />
            <stop offset="0.92" stop-color="#fdfdfb" stop-opacity="0.22" />
            <stop offset="1" stop-color="#fdfdfb" stop-opacity="0.04" />
          </linearGradient>
        ))}
        {markerData.map((m, i) => (
          <mask id={`mkm-${i}`} maskUnits="userSpaceOnUse" x="0" y="0" width="1440" height="900">
            <path class="mk-reveal" d={m.center} fill="none" stroke="#fff" stroke-width={m.w + 12} stroke-linecap="round" stroke-linejoin="round" pathLength="1" />
          </mask>
        ))}
      </defs>
      <g class="drift" style="--phase:0">
        {markerData.map((m, i) => (
          <path class="mk-fill" d={m.ribbon} fill={`url(#mkg-${i})`} mask={`url(#mkm-${i})`} />
        ))}
      </g>
    </g>

  </svg>
</div>

<style>
  .scribble-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }
  .scribble-bg svg { width: 100%; height: 100%; }

  .ink {
    fill: none;
    stroke: var(--c, #ffb454);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-opacity: 0.42;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }
  .ink.faint { stroke-opacity: 0.2; }

  .ink-text {
    fill: var(--c, #ffb454);
    fill-opacity: 0.32;
    clip-path: inset(0 100% 0 0);
    white-space: pre;
  }
  .ink-text.faint { fill-opacity: 0.2; }
  .f-mono { font-family: var(--font-mono); letter-spacing: -0.01em; }
  .f-math { font-family: var(--font-body); font-style: italic; }
  .f-hand { font-family: var(--font-hand); }

  .scribble-group { opacity: 1; }
  .scribble-group.is-hidden { display: none; }
  /* crossfade the outgoing group out while the next one draws itself in */
  .scribble-group.fading { opacity: 0; transition: opacity 1.15s ease; }
  .scribble-group.drawn .ink { stroke-dashoffset: 0; }
  .scribble-group.drawn .ink-text { clip-path: inset(0 0 0 0); }

  /* draw in, then keep shimmering (opacity) so a held group never looks frozen */
  .scribble-group.drawing .ink {
    animation: sb-draw 1.4s ease forwards, sb-shimmer 5s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 32ms), calc(var(--i, 0) * -160ms);
  }
  .scribble-group.drawing .ink-text {
    animation: sb-write 0.8s ease forwards, sb-shimmer 5.6s ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * 32ms), calc(var(--i, 0) * -190ms);
  }
  .scribble-group.erasing .ink {
    animation: sb-erase 0.8s ease forwards;
    animation-delay: calc(var(--i, 0) * 12ms);
  }
  .scribble-group.erasing .ink-text {
    animation: sb-unwrite 0.5s ease forwards;
    animation-delay: calc(var(--i, 0) * 12ms);
  }
  @keyframes sb-draw { from { stroke-dashoffset: 1; } to { stroke-dashoffset: 0; } }
  @keyframes sb-erase { from { stroke-dashoffset: 0; } to { stroke-dashoffset: 1; } }
  @keyframes sb-write { to { clip-path: inset(0 0 0 0); } }
  @keyframes sb-unwrite { to { clip-path: inset(0 0 0 100%); } }
  @keyframes sb-shimmer { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }

  /* fat marker strokes: masked reveal sweeps along the centerline */
  .mk-reveal { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .scribble-group.drawn .mk-reveal { stroke-dashoffset: 0; }
  .scribble-group.drawing .mk-reveal {
    animation: mk-draw 2.6s ease forwards;
    animation-delay: calc(var(--i, 0) * 135ms);
  }
  @keyframes mk-draw { to { stroke-dashoffset: 0; } }


  /* casually-pinned rotation per cluster — rotates around its own bbox center */
  .tilt {
    transform: rotate(var(--tilt, 0deg));
    transform-box: fill-box;
    transform-origin: center;
  }
  /* each cluster slowly drifts on its own phase — ambient life while held */
  .drift {
    animation: sb-float 15s ease-in-out infinite;
    animation-delay: calc(var(--phase, 0) * -2.1s);
    will-change: transform;
  }
  @keyframes sb-float {
    0% { transform: translate(0, 0); }
    25% { transform: translate(5px, -6px); }
    50% { transform: translate(-4px, 4px); }
    75% { transform: translate(4px, 5px); }
    100% { transform: translate(0, 0); }
  }

  @media (max-width: 820px) { .scribble-bg { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .ink { stroke-dashoffset: 0 !important; animation: none !important; }
    .ink-text { clip-path: none !important; animation: none !important; }
    .mk-reveal { stroke-dashoffset: 0 !important; animation: none !important; }
    .drift { animation: none !important; transform: none !important; }
  }
</style>

<script>
  function initScribbles(root: ParentNode) {
    const svg = root.querySelector(".scribble-bg svg");
    if (!svg) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const groups = Array.from(svg.querySelectorAll<SVGGElement>(".scribble-group"));
    if (!groups.length) return;

    // draw order for a nice sequential reveal
    for (const g of groups) {
      Array.from(g.querySelectorAll<SVGElement>(".ink, .ink-text, .mk-reveal")).forEach((el, i) =>
        el.style.setProperty("--i", String(i)),
      );
    }

    if (reduce) {
      groups[0].classList.remove("is-hidden");
      groups[0].classList.add("drawn");
      return;
    }

    const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));
    const count = (g: Element) => g.querySelectorAll(".ink, .ink-text, .mk-reveal").length;
    let running = true;
    let looping = false;
    let last = -1;
    let current: SVGGElement | null = null;

    async function cycle() {
      if (looping) return;
      looping = true;
      while (running) {
        let idx = Math.floor(Math.random() * groups.length);
        if (groups.length > 1 && idx === last) idx = (idx + 1) % groups.length;
        last = idx;
        const next = groups[idx];
        const n = count(next);
        const grp = next.dataset.group;
        const hold = grp === "code" ? 9000 : grp === "math" ? 8000 : grp === "marker" ? 7800 : 6500;

        // incoming: restart its draw-in cleanly
        next.classList.remove("is-hidden", "fading", "drawn", "drawing");
        void next.getBoundingClientRect();
        next.classList.add("drawing");

        // outgoing: crossfade out at the same time (keeps its strokes drawn, just fades)
        if (current && current !== next) {
          const c = current;
          c.classList.add("fading");
          setTimeout(() => c.classList.add("is-hidden"), 1300);
          setTimeout(() => c.classList.remove("fading", "drawing"), 1400);
        }
        current = next;

        await wait(n * 32 + 1400 + hold);
        if (!running) break;
      }
      looping = false;
    }
    cycle();

    const onVis = () => {
      running = document.visibilityState === "visible";
      if (running) cycle();
    };
    document.addEventListener("visibilitychange", onVis);

    return () => {
      running = false;
      document.removeEventListener("visibilitychange", onVis);
    };
  }

  // Fresh scribbles on each page (view-transition navigations included). Stop the previous
  // page's cycle first so it doesn't keep running on the old node. It just animates normally.
  let stopScribbles: (() => void) | null = null;
  function boot() {
    stopScribbles?.();
    stopScribbles = initScribbles(document) ?? null;
  }
  document.addEventListener("astro:page-load", boot);
</script>
