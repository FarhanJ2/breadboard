---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import StatusLine from "../components/StatusLine.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { withBase } from "../lib/url";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured.id);

const projects = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);
// flagship leads (explicit `featured`, else lowest order); the rest fill the row
const flagship = projects.find((p) => p.data.featured) ?? projects[0];
const flag = flagship.data;
const otherBuilds = projects.filter((p) => p.id !== flagship.id);

const statusLabel: Record<string, string> = {
  shipped: "SHIPPED", active: "ACTIVE", research: "RESEARCH", archived: "ARCHIVED",
};

const status = [
  "blahahhahhahah",
  "incoming to RPI — Class of 2030",
  "teaching myself GTSAM",
];
---

<Base title="Farhan Jamil — Workbench">
  <header class="topbar" id="topbar">
    <div class="topbar__inner container">
      <a href={withBase("/")} class="mark" aria-label="Farhan Jamil — home">
        <span class="mark__chip">fj</span>
        <span class="mark__name" aria-hidden="true">farhan jamil<span class="dot">.</span></span>
      </a>
      <nav class="nav">
        <a href={withBase("/blog")}>writing</a>
        <a href={withBase("/projects")}>projects</a>
        <a href={withBase("/connect")}>connect</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <p class="eyebrow hand">welcome to the workbench <span aria-hidden="true">★</span></p>
      <h1 class="name">farhan jamil<span class="dot">.</span></h1>
      <p class="tagline">
        a journal of <em>engineering</em>, robotics &amp; things I actually shipped
      </p>
      <StatusLine items={status} />
    </section>

    <section class="builds">
      <div class="builds__head">
        <h2 class="side__head hand">selected builds —</h2>
        <a href={withBase("/projects")} class="builds__all mono">all projects <span aria-hidden="true">→</span></a>
      </div>

      <a
        href={withBase(`/projects/${flagship.id}`)}
        class="feature"
        data-status={flag.status}
        aria-label={`Open ${flag.title}`}
      >
        <div class="feature__media">
          {flag.cover
            ? <img src={withBase(flag.cover)} alt={flag.coverAlt || flag.title} loading="lazy" decoding="async" />
            : <span class="feature__grid" aria-hidden="true"></span>}
          <span class="feature__badge mono"><span class="led" aria-hidden="true"></span>{statusLabel[flag.status]} · {flag.year}</span>
          <span class="feature__codename mono">{flag.codename}</span>
        </div>
        <div class="feature__body">
          <p class="feature__kicker mono">featured build</p>
          <h3 class="feature__title">{flag.title}</h3>
          <p class="feature__blurb">{flag.blurb}</p>
          {flag.tech.length > 0 && (
            <ul class="tech" aria-label="built with">
              {flag.tech.slice(0, 5).map((t) => <li class="mono">{t}</li>)}
            </ul>
          )}
          <span class="feature__cta mono">open the writeup <span aria-hidden="true">→</span></span>
        </div>
      </a>

      <div class="builds__grid">
        {otherBuilds.map((p) => (
          <a href={withBase(`/projects/${p.id}`)} class="build-link" aria-label={`Open ${p.data.title}`}>
            <ProjectCard project={p} variant="mini" />
          </a>
        ))}
      </div>
    </section>

    <div class="feed">
      <div class="feed__main">
        <PostCard post={featured} variant="featured" />
        <a href={withBase("/blog")} class="feed__all">the full log <span aria-hidden="true">→</span></a>
      </div>

      <aside class="feed__side">
        <h2 class="side__head hand">more from the log —</h2>
        <div class="side__list">
          {rest.map((post) => <PostCard post={post} />)}
        </div>
      </aside>
    </div>
  </main>

  <footer class="container foot">
    <span>Townsend Harris '26 · RPI ECSE/CSE '30</span>
    <span class="mono">breadboard — built in the open</span>
  </footer>
</Base>

<style>
  /* --- sticky top bar --- */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .topbar.scrolled {
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(10px) saturate(1.1);
    -webkit-backdrop-filter: blur(10px) saturate(1.1);
    border-bottom-color: var(--line-soft);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px 20px;
    flex-wrap: wrap;
    padding-top: 24px;
    padding-bottom: 24px;
    transition: padding 0.25s ease;
  }
  .topbar.scrolled .topbar__inner { padding-top: 13px; padding-bottom: 13px; }

  .mark { display: flex; align-items: center; text-decoration: none; }
  .mark:hover { text-decoration: none; }
  .mark__chip {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
    color: var(--bg);
    background: var(--amber);
    padding: 5px 9px;
    border-radius: 7px;
    flex: none;
  }
  /* brand name — slides out from behind the logo once the hero scrolls past */
  .mark__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    transform: translateX(-8px);
    transition:
      max-width 0.5s cubic-bezier(0.22, 0.7, 0.2, 1),
      opacity 0.35s ease,
      transform 0.5s cubic-bezier(0.22, 0.7, 0.2, 1),
      margin-left 0.5s cubic-bezier(0.22, 0.7, 0.2, 1);
  }
  .mark__name .dot { color: var(--amber); }
  .topbar.named .mark__name {
    max-width: 12ch;
    opacity: 1;
    transform: none;
    margin-left: 11px;
  }

  .nav { display: flex; gap: clamp(18px, 3vw, 34px); }
  .nav a {
    font-family: var(--font-hand);
    font-size: 1.35rem;
    color: var(--ink-soft);
  }
  .nav a:hover { color: var(--amber); text-decoration: none; }

  @media (prefers-reduced-motion: reduce) {
    .mark__name { transition: opacity 0.2s ease; }
  }

  /* --- hero --- */
  .hero { padding: clamp(28px, 7vw, 72px) 0 clamp(30px, 5vw, 54px); max-width: 40ch; }
  .eyebrow { font-size: 1.4rem; margin: 0 0 6px; }
  .name {
    margin: 0;
    font-size: clamp(3.2rem, 9vw, 6rem);
    font-weight: 600;
    font-optical-sizing: auto;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }
  .name .dot { color: var(--amber); }
  .tagline {
    margin: 0.5rem 0 1.3rem;
    font-size: clamp(1.15rem, 2.4vw, 1.5rem);
    color: var(--ink-soft);
    font-weight: 300;
  }
  .tagline em { color: var(--blueprint); font-style: italic; }

  /* --- selected builds --- */
  .builds { padding-bottom: clamp(38px, 6vw, 60px); }
  .builds__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .builds__all { font-size: 0.8rem; letter-spacing: 0.04em; white-space: nowrap; }

  /* flagship feature card — photo-led, whole card is the link */
  .feature {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(16px, 2.5vw, 30px);
    background: var(--bg-raise);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 14px;
    margin-bottom: 16px;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .feature:hover {
    transform: translateY(-2px);
    box-shadow: 0 18px 44px -22px rgba(0, 0, 0, 0.8);
    text-decoration: none;
  }
  .feature[data-status="shipped"] { --st: var(--phosphor); }
  .feature[data-status="active"] { --st: var(--amber); }
  .feature[data-status="research"] { --st: var(--blueprint); }
  .feature[data-status="archived"] { --st: var(--ink-faint); }

  .feature__media {
    position: relative;
    min-height: 236px;
    border-radius: 11px;
    overflow: hidden;
    background: var(--bg-inset);
    border: 1px solid var(--line-soft);
  }
  .feature__media img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }
  .feature:hover .feature__media img { transform: scale(1.035); }
  .feature__media::after {
    content: ""; position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to top, rgba(9, 11, 16, 0.82) 0%, rgba(9, 11, 16, 0) 44%),
      linear-gradient(to bottom, rgba(9, 11, 16, 0.55) 0%, rgba(9, 11, 16, 0) 32%);
  }
  .feature__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(120, 150, 230, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120, 150, 230, 0.07) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(130% 90% at 30% 35%, #000 40%, transparent 92%);
  }
  .feature__badge {
    position: absolute; top: 12px; left: 13px; z-index: 2;
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 11px; letter-spacing: 0.12em; color: var(--st);
  }
  .feature__badge .led {
    width: 8px; height: 8px; border-radius: 50%; flex: none;
    background: var(--st); box-shadow: 0 0 8px 0 var(--st);
  }
  .feature__codename {
    position: absolute; left: 15px; bottom: 12px; z-index: 2;
    font-weight: 600; font-size: clamp(1.5rem, 3vw, 2.1rem);
    letter-spacing: -0.01em; color: var(--ink);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.65);
  }

  .feature__body { display: flex; flex-direction: column; padding: 8px 10px 8px 2px; }
  .feature__kicker { color: var(--ink-faint); letter-spacing: 0.14em; font-size: 11px; margin: 4px 0 9px; }
  .feature__title {
    margin: 0 0 8px; font-size: clamp(1.4rem, 2.4vw, 1.9rem);
    font-weight: 600; letter-spacing: -0.015em; color: var(--ink);
    transition: color 0.15s ease;
  }
  .feature:hover .feature__title { color: var(--amber); }
  .feature__blurb { margin: 0; color: var(--ink-soft); font-size: 1.02rem; line-height: 1.5; }
  .feature .tech { list-style: none; display: flex; flex-wrap: wrap; gap: 6px; margin: 14px 0 0; padding: 0; }
  .feature .tech li {
    font-size: 10.5px; letter-spacing: 0.06em; color: var(--ink-soft);
    border: 1px solid var(--line); border-radius: 5px; padding: 3px 7px 2px;
  }
  .feature__cta {
    margin-top: auto; padding-top: 16px;
    font-size: 0.82rem; letter-spacing: 0.03em; color: var(--amber);
  }

  .builds__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .build-link {
    display: block;
    border-radius: 12px;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .build-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -14px rgba(0, 0, 0, 0.7);
    text-decoration: none;
  }
  @media (max-width: 620px) {
    .feature { grid-template-columns: 1fr; }
    .feature__media { min-height: 200px; }
  }

  /* --- feed --- */
  .feed {
    display: grid;
    grid-template-columns: 1.55fr 1fr;
    gap: clamp(24px, 4vw, 52px);
    align-items: start;
    padding-bottom: 80px;
  }
  /* grid children default to min-width:auto — let them shrink instead of overflowing */
  .feed > * { min-width: 0; }
  .feed__all {
    display: inline-block;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
  }

  .feed__side { position: sticky; top: 84px; }
  .side__head { font-size: 1.55rem; color: var(--amber); margin: 0 0 6px; }
  .side__list { display: flex; flex-direction: column; }

  .foot {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 26px;
    padding-bottom: 40px;
    border-top: 1px solid var(--line-soft);
    color: var(--ink-faint);
    font-size: 0.9rem;
  }

  @media (max-width: 860px) {
    .feed { grid-template-columns: 1fr; }
    .feed__side { position: static; margin-top: 10px; }
  }
</style>

<script>
  // re-run on every view-transition navigation; clean up old listeners so they don't stack
  let cleanup: (() => void) | null = null;
  function setupHeader() {
    cleanup?.();
    cleanup = null;
    const bar = document.getElementById("topbar");
    const heroName = document.querySelector<HTMLElement>(".hero .name");
    if (!bar || !heroName) return;
    let ticking = false;
    const update = () => {
      ticking = false;
      bar.classList.toggle("scrolled", window.scrollY > 4);
      const revealAt = bar.offsetHeight - 6;
      bar.classList.toggle("named", heroName.getBoundingClientRect().bottom < revealAt);
    };
    const onScroll = () => { if (!ticking) { requestAnimationFrame(update); ticking = true; } };
    addEventListener("scroll", onScroll, { passive: true });
    addEventListener("resize", update, { passive: true });
    update();
    cleanup = () => {
      removeEventListener("scroll", onScroll);
      removeEventListener("resize", update);
    };
  }
  document.addEventListener("astro:page-load", setupHeader);
</script>
